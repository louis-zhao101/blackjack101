{
  "name": "blackjack101",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm --filter @blackjack101/web dev",
    "build": "pnpm --filter @blackjack101/core build && pnpm --filter @blackjack101/web build",
    "test": "pnpm --filter @blackjack101/core test",
    "test:all": "pnpm -r test",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
